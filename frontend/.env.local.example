# Argus Vision frontend — local environment.
# Copy to `.env.local` (gitignored) and fill in what you need.
# Everything here is OPTIONAL: with no values the UI still runs and the live
# debate arguments fall back to deterministic local text.

# --- Backend endpoints (defaults assume the nginx-fronted docker stack) ---
# NEXT_PUBLIC_API_URL=http://localhost/api
# NEXT_PUBLIC_WS_URL=ws://localhost/ws
# NEXT_PUBLIC_SITE_URL=http://localhost

# --- Demo without a backend -------------------------------------------------
# Plays a scripted debate (mock heatmaps included) with no WebSocket/backend.
# NEXT_PUBLIC_DEBATE_MOCK_MODE=true

# --- Debate argument text (LLM-free, default) -------------------------------
# The turn-by-turn debate is driven by a real belief-revision engine; the words
# come from retrieval over a curated argument bank. The embedder is pluggable:
#   "lexical"      (default) — zero install, no download, works offline.
#   "transformers"           — real MiniLM (384-d) semantic embeddings, loaded
#                              from a CDN at runtime (no npm install). First run
#                              downloads ~25MB once, then cached in the browser.
# NEXT_PUBLIC_DEBATE_EMBEDDER=lexical
# Optional CDN override for transformers.js:
# NEXT_PUBLIC_TRANSFORMERS_URL=https://esm.sh/@xenova/transformers@2.17.2

# --- Optional: LLM text backend (legacy, not used by default) ---------------
# The repo still ships a free OpenAI-compatible proxy (/api/debate-llm). It is no
# longer wired into the debate (which uses embedding retrieval), but the route +
# keys below remain available if you want to revive LLM-written prose.
# The signature "two minds arguing" feature streams from a free provider via the
# server-side proxy at /api/debate-llm. The API key NEVER reaches the browser.
# Leave LLM_API_KEY empty to use the built-in deterministic fallback (no key,
# no cost, fully offline).
#
# Recommended: Groq (fastest free tier, ~1k–14k requests/day, no credit card).
#   Get a key: https://console.groq.com/keys
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
# High-volume / lower-latency alternative: LLM_MODEL=llama-3.1-8b-instant
#
# Alternative provider: OpenRouter (more models, ~50 free requests/day).
#   LLM_PROVIDER=openrouter
#   LLM_API_KEY=sk-or-...
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# Advanced: override the base URL for any other OpenAI-compatible endpoint.
#   LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions
#
# Provider-specific keys are also honoured if LLM_API_KEY is unset:
#   GROQ_API_KEY=...
#   OPENROUTER_API_KEY=...
