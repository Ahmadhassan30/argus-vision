# Argus Vision — Docker Compose environment.
#
# Copy this file to `.env` (same directory as docker-compose.yml) only if you need
# to override a default:
#
#     cp .env.example .env
#
# Everything here is OPTIONAL. With no .env at all the stack still builds and runs.
# The consensus pipeline is fully numerical (23-dim feature vector); there is no
# LLM / Groq dependency any more.

# Comma-separated CORS origins permitted by the backend (defaults shown).
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Filename of the consensus StandardScaler saved by 04_train_consensus.ipynb.
# Must sit next to consensus_best.pth in MODEL_CHECKPOINT_DIR.
# CONSENSUS_SCALER=consensus_scaler.pkl
