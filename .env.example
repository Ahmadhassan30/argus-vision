# Argus Vision — Docker Compose environment.
#
# Copy this file to `.env` (same directory as docker-compose.yml) to have Docker
# Compose inject these values into the backend container, e.g.:
#
#     cp .env.example .env
#     # then edit .env and set your Groq key
#
# Everything here is OPTIONAL. With no .env at all the stack still builds and runs:
# the agents use ImageNet-pretrained weights and the debate uses deterministic
# fallback arguments. Set GROQ_API_KEY to enable the live LLM-generated debate text.

# Groq API key — get one at https://console.groq.com/keys
GROQ_API_KEY=

# Groq model used for the two debate rounds.
GROQ_MODEL=llama-3.3-70b-versatile
